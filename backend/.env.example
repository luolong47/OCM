# Copy to .env and adjust. All values have sane defaults if omitted.

# SQLite database location (relative to the backend working dir).
DATABASE_URL=sqlite:data/ocm.db?mode=rwc

# Where the HTTP server listens.
OCM_BIND=127.0.0.1:8787

# models.dev metadata catalog (machine-readable dataset opencode itself uses).
OCM_MODELS_DEV_URL=https://models.dev/api.json
# How long the models.dev catalog is cached, in seconds (default 1 day).
OCM_MODELS_DEV_TTL_SECS=86400

# How long each provider's live /v1/models id-list is cached, in seconds.
OCM_PROVIDER_LIST_TTL_SECS=300

# Target opencode.json. Defaults to ~/.config/opencode/opencode.json.
# OCM_OPENCODE_CONFIG=/home/you/.config/opencode/opencode.json

# Local OCM settings file. Defaults to ~/.config/ocm/settings.json.
# OCM_SETTINGS_PATH=/home/you/.config/ocm/settings.json

# Log filter.
RUST_LOG=ocm_backend=debug,tower_http=info,info
